{
  // CLI type-check gate for the test suites (tests/ + src/**/*.spec.ts).
  //
  // Neither the build (`tsc -p tsconfig.build.json`) nor the linter type-checks
  // the tests: tsconfig.build.json excludes `tests` and `**/*.spec.ts`, and
  // vitest runs through unplugin-swc, which transpiles without type-checking. So
  // type errors in specs (wrong TestHelper arity, missing imports, stale API
  // shapes) land unnoticed. `pnpm run typecheck:tests` (wired into `check`) runs
  // tsc over this config to close that gap.
  //
  // Extends the base tsconfig — path aliases, decorators, es2022 target,
  // vitest/globals — so specs resolve exactly as they do under vitest. Adds only
  // the test file scope, the Node ambient types, and noEmit; it is a pure gate
  // (emits nothing). Covers every spec location the two vitest configs run:
  // src/**/*.spec.ts, tests/unit/**, tests/**/*.e2e-spec.ts, tests/stories/**.
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["vitest/globals", "node"]
  },
  "include": ["src/**/*.spec.ts", "tests/**/*.ts"]
}
